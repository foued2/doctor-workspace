0.
function max(iterable):
    if iterable is empty:
        raise ValueError("max() arg is an empty sequence")

    current_max = iterable[0]  # Initialize with the first element
    for each element in iterable starting from the second element:
        if element > current_max:
            current_max = element
    return current_max

