  "solve_n_queens": {
    "spec": {
      "display_name": "N-Queens",
      "constraints": {},
      "difficulty": "hard",
      "tags": [],
      "problem_id": "solve_n_queens",
      "reference_solution": "def solveNQueens(n):\n    results = []\n    cols = set()\n    d1 = set()\n    d2 = set()\n    row = []\n\n    def backtrack():\n        if len(row) == n:\n            board = ['.' * c + 'Q' + '.' * (n - c - 1) for c in row]\n            results.append(board)\n            return\n        for c in range(n):\n            if c in cols or (len(row) - c) in d1 or (len(row) + c) in d2:\n                continue\n            cols.add(c)\n            d1.add(len(row) - c)\n            d2.add(len(row) + c)\n            row.append(c)\n            backtrack()\n            row.pop()\n            cols.remove(c)\n            d1.remove(len(row) - c)\n            d2.remove(len(row) + c)\n\n    backtrack()\n    return results\n"
    },
