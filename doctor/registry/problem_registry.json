  "reverse_integer": {
    "spec": {
      "display_name": "Reverse Integer",
      "constraints": {},
      "difficulty": "medium",
      "tags": [],
      "problem_id": "reverse_integer",
      "reference_solution": "def reverse(x):\n    sign = -1 if x < 0 else 1\n    x = abs(x)\n    rev = 0\n    while x != 0:\n        rev = rev * 10 + x % 10\n        x //= 10\n    rev *= sign\n    if rev < -2**31 or rev > 2**31 - 1:\n        return 0\n    return rev\n"
    },
    "execution": {
      "test_cases": [
        {
          "input": [
            123
          ],
          "expected": 321,
          "label": "basic_positive",
          "source": "manual"
        },
