  "valid_parentheses": {
    "spec": {
      "display_name": "Valid Parentheses",
      "constraints": {},
      "difficulty": "easy",
      "tags": [],
      "problem_id": "valid_parentheses",
      "reference_solution": "def isValid(s):\n    stack = []\n    mapping = {')': '(', ']': '[', '}': '{'}\n    for ch in s:\n        if ch in mapping:\n            top = stack.pop() if stack else '#'\n            if mapping[ch] != top:\n                return False\n        else:\n            stack.append(ch)\n    return not stack\n"
    },
    "execution": {
      "test_cases": [
        {
          "input": [
            "()"
          ],
          "expected": true,
          "label": "basic",
          "source": "manual"
        },
        {
          "input": [
            "()[]{}"
          ],
          "expected": true,
          "label": "all_types",
          "source": "manual"
        },
        {
          "input": [
            "(]"
          ],
          "expected": false,
          "label": "wrong_type",
          "source": "boundary"
        },
        {
          "input": [
            "([)]"
          ],
          "expected": false,
          "label": "wrong_order",
          "source": "boundary"
        },
        {
          "input": [
            "("
          ],
          "expected": false,
          "label": "unclosed",
          "source": "boundary"
        },
        {
          "input": [
            "{[]}"
          ],
          "expected": true,
          "label": "nested",
          "source": "manual"
        },
        {
          "input": [
            ""
          ],
          "expected": true,
          "label": "empty",
          "source": "boundary"
        }
      ]
    },
    "normalization": {
      "function_names": [
        "isValid"
      ]
    }
  },
  "merge_two_sorted_lists": {
    "spec": {
      "display_name": "Merge Two Sorted Lists",
      "constraints": {},
      "difficulty": "easy",
      "tags": [],
      "problem_id": "merge_two_sorted_lists",
      "reference_solution": "\nclass ListNode:\n    def __init__(self, val=0, next=None):\n        self.val = val\n        self.next = next\n\ndef mergeTwoLists(l1, l2):\n    dummy = ListNode()\n    curr = dummy\n    while l1 and l2:\n        if l1.val <= l2.val:\n            curr.next = l1\n            l1 = l1.next\n        else:\n            curr.next = l2\n            l2 = l2.next\n        curr = curr.next\n    curr.next = l1 or l2\n    return dummy.next\n",
      "order_sensitive": true
    },
    "execution": {
      "test_cases": [
        {
          "input": [
            [
              1,
              2,
              4
            ],
            [
              1,
              3,
              4
            ]
          ],
          "expected": [
            1,
            1,
            2,
            3,
            4,
            4
          ],
          "label": "basic",
          "source": "manual"
        },
        {
          "input": [
            null,
            null
          ],
          "expected": [],
          "label": "both_empty",
          "source": "boundary"
        },
        {
          "input": [
            null,
            [
              0
            ]
          ],
          "expected": [
            0
          ],
          "label": "one_empty",
          "source": "boundary"
        },
        {
          "input": [
            [
              1,
              3,
              5
            ],
            [
              2,
              4,
              6
            ]
          ],
          "expected": [
            1,
            2,
            3,
            4,
            5,
            6
          ],
          "label": "interleaved",
          "source": "boundary"
        },
        {
          "input": [
            [
              5
            ],
            [
              1,
              2,
              3
            ]
          ],
          "expected": [
            1,
            2,
            3,
            5
          ],
          "label": "one_larger",
          "source": "boundary"
        }
      ]
    },
    "normalization": {
      "function_names": [
        "mergeTwoLists"
      ]
    }
  },
