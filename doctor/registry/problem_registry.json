  "int_to_roman": {
    "spec": {
      "display_name": "Integer to Roman",
      "constraints": {},
      "difficulty": "medium",
      "tags": [],
      "problem_id": "int_to_roman",
      "reference_solution": "def intToRoman(num):\n    vals = [1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1]\n    syms = [\"M\", \"CM\", \"D\", \"CD\", \"C\", \"XC\", \"L\", \"XL\", \"X\", \"IX\", \"V\", \"IV\", \"I\"]\n    result = \"\"\n    for v, s in zip(vals, syms):\n        while num >= v:\n            result += s\n            num -= v\n    return result\n"
    },
    "execution": {
      "test_cases": [
        {
          "input": [
            3
          ],
          "expected": "III",
          "label": "basic",
          "source": "manual"
        },
        {
          "input": [
            58
          ],
          "expected": "LVIII",
          "label": "mixed",
          "source": "manual"
        },
        {
          "input": [
            1994
          ],
          "expected": "MCMXCIV",
          "label": "subtractive",
          "source": "boundary"
        },
        {
          "input": [
            1
          ],
          "expected": "I",
          "label": "single",
          "source": "boundary"
        },
        {
          "input": [
            3999
          ],
          "expected": "MMMCMXCIX",
          "label": "max",
          "source": "manual"
        }
      ]
    },
    "normalization": {
